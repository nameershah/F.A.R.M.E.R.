# =============================================================
# F.A.R.M.E.R. Backend — Environment Variables Template
# Copy this file to .env and fill in your own values.
# NEVER commit .env — it is listed in .gitignore.
# =============================================================

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use * only in local dev; NEVER in production.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────
# Window in milliseconds (default 15 min) and max requests per window.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30

# ── AI providers (never commit real keys) ─────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
# Optional — default llama-3.1-8b-instant (fast). Use llama-3.3-70b-versatile for higher quality.
GROQ_MODEL=llama-3.1-8b-instant

# ── MongoDB (optional — query logging only) ───────────────────
# Core agent flow works without this; leave blank to disable logging.
MONGODB_URI=

# ── Logs access key (CONFIDENTIALITY) ────────────────────────
# Any strong random string. Protects GET /api/logs from public access.
# Leave blank to disable the logs endpoint entirely (fail-closed).
# Generate one with: openssl rand -hex 32
LOGS_API_KEY=

# ── Default coordinates (Peshawar, KP) ───────────────────────
DEFAULT_LAT=34.0151
DEFAULT_LON=71.5249
